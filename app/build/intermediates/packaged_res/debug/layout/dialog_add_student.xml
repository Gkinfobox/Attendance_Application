<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="➕ Add Student" android:textColor="@color/text_light"
            android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="20dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="FULL NAME" android:textColor="@color/muted_light"
            android:textSize="11sp" android:textAllCaps="true" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_ae_name"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Full name" android:background="@drawable/bg_card" android:padding="13dp"
            android:textColor="@color/text_light" android:textColorHint="@color/muted_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="REGISTER NUMBER" android:textColor="@color/muted_light"
            android:textSize="11sp" android:textAllCaps="true" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_ae_empid"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="e.g. REG001" android:background="@drawable/bg_card" android:padding="13dp"
            android:textColor="@color/text_light" android:textColorHint="@color/muted_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="CLASS / SECTION" android:textColor="@color/muted_light"
            android:textSize="11sp" android:textAllCaps="true" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_ae_class"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="e.g. 11-A, CSE-B" android:background="@drawable/bg_card" android:padding="13dp"
            android:textColor="@color/text_light" android:textColorHint="@color/muted_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="PARENT MOBILE" android:textColor="@color/muted_light"
            android:textSize="11sp" android:textAllCaps="true" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_ae_mobile"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Parent mobile number" android:inputType="phone"
            android:background="@drawable/bg_card" android:padding="13dp"
            android:textColor="@color/text_light" android:textColorHint="@color/muted_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="EMAIL" android:textColor="@color/muted_light"
            android:textSize="11sp" android:textAllCaps="true" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_ae_email"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Email address" android:inputType="textEmailAddress"
            android:background="@drawable/bg_card" android:padding="13dp"
            android:textColor="@color/text_light" android:textColorHint="@color/muted_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="DEPARTMENT" android:textColor="@color/muted_light"
            android:textSize="11sp" android:textAllCaps="true" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spin_ae_dept"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/bg_card" android:padding="4dp"
            android:entries="@array/departments"
            android:layout_marginBottom="8dp"/>
        <EditText android:id="@+id/et_ae_dept_other"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Enter department..." android:visibility="gone"
            android:background="@drawable/bg_card" android:padding="13dp"
            android:textColor="@color/text_light" android:textColorHint="@color/muted_light"
            android:layout_marginBottom="14dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="PASSWORD" android:textColor="@color/muted_light"
            android:textSize="11sp" android:textAllCaps="true" android:textStyle="bold" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/et_ae_pwd"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="Set login password" android:inputType="textPassword"
            android:background="@drawable/bg_card" android:padding="13dp"
            android:textColor="@color/text_light" android:textColorHint="@color/muted_light"
            android:layout_marginBottom="20dp"/>

        <Button android:id="@+id/btn_ae_add"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="Add Student" android:background="@drawable/bg_btn_red"
            android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="10dp"/>
        <Button android:id="@+id/btn_ae_cancel"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Cancel" android:background="@drawable/bg_card"
            android:textColor="@color/text_light" android:textStyle="bold"/>

    </LinearLayout>
</ScrollView>
