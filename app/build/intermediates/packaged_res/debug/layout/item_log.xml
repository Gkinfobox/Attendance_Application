<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp">

    <!-- Icon -->
    <FrameLayout android:layout_width="36dp" android:layout_height="36dp"
        android:layout_marginEnd="12dp">
        <View android:layout_width="match_parent" android:layout_height="match_parent"
            android:background="@drawable/bg_badge_out" android:backgroundTint="#1AE63946"/>
        <TextView android:id="@+id/tv_log_icon"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:gravity="center" android:textSize="16sp"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_log_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_log_meta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/muted_light" android:textSize="11sp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Badge -->
    <TextView android:id="@+id/tv_log_badge"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:padding="4dp" android:paddingStart="10dp" android:paddingEnd="10dp"
        android:textSize="10sp" android:textStyle="bold" android:textAllCaps="true"
        android:background="@drawable/bg_badge_in"/>

</LinearLayout>
