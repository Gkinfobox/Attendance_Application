<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Fragment container -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav"/>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="@drawable/bg_bottom_nav"
        android:elevation="8dp">

        <LinearLayout android:id="@+id/nav_home"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🏠" android:textSize="20sp"/>
            <TextView android:id="@+id/tv_nav_home"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/red"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_attend"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="✅" android:textSize="20sp"/>
            <TextView android:id="@+id/tv_nav_attend"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Attend" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_light"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_summary"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📊" android:textSize="20sp"/>
            <TextView android:id="@+id/tv_nav_summary"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Summary" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_light"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_admin"
            android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center" android:clickable="true" android:focusable="true"
            android:visibility="gone"
            android:background="?attr/selectableItemBackground">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙️" android:textSize="20sp"/>
            <TextView android:id="@+id/tv_nav_admin"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Teacher" android:textSize="10sp" android:textStyle="bold"
                android:textColor="@color/muted_light"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
