<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_card"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_marginBottom="10dp">

    <!-- Avatar -->
    <FrameLayout android:layout_width="42dp" android:layout_height="42dp"
        android:layout_marginEnd="12dp">
        <View android:layout_width="match_parent" android:layout_height="match_parent"
            android:background="@drawable/bg_avatar"/>
        <TextView android:id="@+id/tv_emp_initial"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:gravity="center" android:text="?" android:textColor="@color/white"
            android:textSize="18sp" android:textStyle="bold"/>
    </FrameLayout>

    <!-- Info -->
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tv_emp_name"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_light" android:textSize="14sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tv_emp_meta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/muted_light" android:textSize="11sp" android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Remove Button -->
    <Button android:id="@+id/btn_remove_emp"
        android:layout_width="wrap_content" android:layout_height="32dp"
        android:text="🗑 Remove" android:textSize="11sp" android:textStyle="bold"
        android:textColor="@color/red" android:backgroundTint="#1AE63946"
        android:paddingStart="10dp" android:paddingEnd="10dp"/>

</LinearLayout>
